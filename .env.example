NODE_ENV=production
PORT=8080

# Supabase aurum-databot
SUPABASE_URL=https://kfyttrhozamvshkdwtfb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# API auth · required, min 32 chars (generate: openssl rand -hex 32)
AURUM_ADS_ENGINE_API_KEY=

# Meta Marketing API (Phase 2)
META_APP_ID=
META_APP_SECRET=
META_PAGE_ID=
META_AD_ACCOUNT_ID=act_23845968344460231
META_PAGE_ACCESS_TOKEN=
META_API_VERSION=v23.0
META_API_BASE_URL=https://graph.facebook.com

# Mock mode toggle — skip real Meta API calls (set to false when creds ready)
META_MOCK_MODE=true

# TikTok Marketing API (Phase 3)
TIKTOK_MOCK_MODE=true
TIKTOK_ADVERTISER_ID=placeholder_advertiser_id
TIKTOK_ACCESS_TOKEN=placeholder_token_will_replace_later
TIKTOK_APP_ID=placeholder_app_id
TIKTOK_APP_SECRET=placeholder_app_secret
TIKTOK_PIXEL_ID=D8QGJRRC77U082M868CG
TIKTOK_API_VERSION=v1.3
TIKTOK_API_BASE_URL=https://business-api.tiktok.com/open_api

# Phase 1+ · Platform credentials (stub, deferred)
LINE_OA_ACCESS_TOKEN=
LINE_OA_CHANNEL_SECRET=
META_VERIFY_TOKEN=

# Phase 1 · PR-1 · Lead capture webhooks (Meta + TikTok)
# Skip signature verification + treat all webhooks as trusted (local testing).
WEBHOOK_MOCK_MODE=true
# Meta GET verification handshake token (any random string; must match the
# value entered in the Facebook App → Webhooks dashboard).
META_WEBHOOK_VERIFY_TOKEN=replace_with_random_string_here
# TikTok webhook HMAC secret (X-Tt-Signature). Generate: openssl rand -hex 32
TIKTOK_WEBHOOK_SECRET=replace_with_random_string_here
# Meta HMAC (X-Hub-Signature-256) reuses META_APP_SECRET above, and the Graph
# API lead fetch reuses META_PAGE_ACCESS_TOKEN above.

# Notification channels (all optional · each silently skips if its vars absent)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=leads@aurumlive.com
LEAD_NOTIFICATION_EMAIL=porforex599@gmail.com
LINE_CHANNEL_ACCESS_TOKEN=
